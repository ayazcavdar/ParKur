#!/bin/sh
# ParKur live-bottom hook: switch_root öncesi rootfs'e enjeksiyon
PREREQ=""
prereqs() { echo "$PREREQ"; }
case "$1" in prereqs) prereqs; exit 0;; esac

PAYLOAD="/parkur-payload"
[ -d "$PAYLOAD" ] || exit 0

# systemd servisini kopyala
if [ -f "$PAYLOAD/parkur.service" ]; then
    cp "$PAYLOAD/parkur.service" "${rootmnt}/etc/systemd/system/"
    mkdir -p "${rootmnt}/etc/systemd/system/multi-user.target.wants"
    ln -sf ../parkur.service \
        "${rootmnt}/etc/systemd/system/multi-user.target.wants/parkur.service"
fi

# Kurulum motorunu kopyala
if [ -f "$PAYLOAD/parkur-engine.sh" ]; then
    mkdir -p "${rootmnt}/opt/parkur"
    cp "$PAYLOAD/parkur-engine.sh" "${rootmnt}/opt/parkur/"
    chmod +x "${rootmnt}/opt/parkur/parkur-engine.sh"
fi
